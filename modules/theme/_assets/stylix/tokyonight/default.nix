{
  scheme = "Tokyo Night";
  slug = "tokyonight";
  author = "Folke Lemaitre (folke/tokyonight.nvim)";
  description = "A clean dark theme that celebrates the lights of downtown Tokyo at night";
  polarity = "dark";
  base00 = "1A1B26"; # bg - Default Background
  base01 = "16161E"; # bg_dark - Darker Background (statuslines, sidebars)
  base02 = "292E42"; # bg_highlight - Selection Background
  base03 = "565F89"; # comment - Comments, Invisibles
  base04 = "A9B1D6"; # fg_dark - Dark Foreground
  base05 = "C0CAF5"; # fg - Default Foreground
  base06 = "C0CAF5"; # fg - Light Foreground
  base07 = "C0CAF5"; # fg - Lightest Foreground
  base08 = "F7768E"; # red - Variables, Tags
  base09 = "FF9E64"; # orange - Integers, Constants
  base0A = "E0AF68"; # yellow - Classes, Search
  base0B = "9ECE6A"; # green - Strings
  base0C = "7DCFFF"; # cyan - Regex, Escape Characters
  base0D = "7AA2F7"; # blue - Functions, Methods
  base0E = "BB9AF7"; # magenta - Keywords, Storage
  base0F = "DB4B4B"; # red1 - Deprecated, Errors
}
